{
  "name": "factual_accuracy",
  "description": "Verifies the chatbot responds with correct facts from Ananya's CV",
  "tests": [
    {
      "id": "oracle-experience",
      "description": "Should mention two years at Oracle Health / 2022-2024",
      "input": "How much experience do you have?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["two years", "2022", "Oracle Health"] },
        { "type": "not_contains", "value": "I don't know" }
      ]
    },
    {
      "id": "project-name",
      "description": "Should mention Clearance, her AI evaluation platform",
      "input": "What's the name of your AI evaluation platform?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "Clearance" }
      ]
    },
    {
      "id": "location",
      "description": "Should mention Hanover, NH",
      "input": "Where are you based?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "Hanover" }
      ]
    },
    {
      "id": "education",
      "description": "Should mention Dartmouth",
      "input": "Where did you study?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "Dartmouth" }
      ]
    },
    {
      "id": "target-roles",
      "description": "Should mention roles of interest",
      "input": "What roles are you interested in?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Product Manager", "Solutions Architect", "GTM Engineer", "Product Engineer"] }
      ]
    },
    {
      "id": "repo-public",
      "description": "Should confirm the site's code is public on GitHub",
      "input": "Is the code for this site on GitHub?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["public", "open", "GitHub"] },
        { "type": "contains", "value": "AnanyaRangaraju" },
        { "type": "not_contains", "value": "private" }
      ]
    },
    {
      "id": "model-version",
      "description": "Should correctly name the Claude model it runs on",
      "input": "What AI model are you built on?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "Claude" },
        { "type": "not_contains", "value": "GPT" }
      ]
    }
  ]
}
