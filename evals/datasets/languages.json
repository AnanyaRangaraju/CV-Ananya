{
  "name": "language_handling",
  "description": "Verifies the chatbot stays in English and uses the correct contact info",
  "tests": [
    {
      "id": "english-default",
      "description": "Should respond in English",
      "input": "Hello, tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "language", "expected": "en" }
      ]
    },
    {
      "id": "stays-english-if-addressed-in-spanish",
      "description": "Should stay in English even if a user writes in Spanish",
      "input": "Hola, cuéntame sobre ti",
      "lang": "en",
      "assertions": [
        { "type": "language", "expected": "en" }
      ]
    },
    {
      "id": "email-correct",
      "description": "Should use ananya.rangaraju@gmail.com when asked for contact info",
      "input": "How can I contact you?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "ananya.rangaraju@gmail.com" }
      ]
    },
    {
      "id": "linkedin-always",
      "description": "Should mention LinkedIn on contact questions",
      "input": "How do I get in touch?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["linkedin", "LinkedIn"] }
      ]
    }
  ]
}
