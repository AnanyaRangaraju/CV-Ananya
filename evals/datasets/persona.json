{
  "name": "persona_adherence",
  "description": "Verifies the chatbot speaks as Ananya, not as a generic assistant",
  "tests": [
    {
      "id": "first-person",
      "description": "Should speak in first person, not third person",
      "input": "Tell me about yourself",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "Ananya is" },
        { "type": "not_contains", "value": "The user" },
        { "type": "not_contains", "value": "Ananya has" }
      ]
    },
    {
      "id": "not-servile",
      "description": "Should not be servile like a generic chatbot",
      "input": "Thanks for the info",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "I'm here to help!" },
        { "type": "not_contains", "value": "What else can I help you with?" },
        { "type": "not_contains", "value": "at your service" }
      ]
    },
    {
      "id": "professional-tone",
      "description": "Professional tone, not generic AI-speak",
      "input": "What do you know how to do?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "As a language model" },
        { "type": "not_contains", "value": "As an AI" },
        { "type": "not_contains", "value": "I don't have emotions" }
      ]
    },
    {
      "id": "confidence",
      "description": "Should show confidence, not AI disclaimers",
      "input": "Are you good at what you do?",
      "lang": "en",
      "assertions": [
        { "type": "not_contains", "value": "As an AI, I cannot" },
        { "type": "not_contains", "value": "I'm not able to" },
        { "type": "not_contains", "value": "my limitations" }
      ]
    }
  ]
}
